
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /user_progress/{userId} {
      allow get: if true; // Public profiles
      allow list: if true;
      allow create, update: if isOwner(userId);

      match /challenge_activities/{activityId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /public_gallery/{activityId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userProgressId == request.auth.uid;
      allow update: if isSignedIn(); // Allow likes
      allow delete: if isSignedIn() && resource.data.userProgressId == request.auth.uid;
    }
  }
}
