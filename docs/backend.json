
{
  "entities": {
    "UserProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProgress",
      "type": "object",
      "description": "Tracks the overall progress, streaks, and aggregated performance for a local, anonymous user, including gamification and psychomotor levels.",
      "properties": {
        "id": { "type": "string" },
        "lastActiveDate": { "type": "string", "format": "date-time" },
        "totalChallengesCompleted": { "type": "number" },
        "currentStreak": { "type": "number" },
        "longestStreak": { "type": "number" },
        "totalTimeSpentSeconds": { "type": "number" },
        "skillLevel": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "ageGroup": { "type": "string", "enum": ["preschool", "school_age", "adolescent_adult"] },
        "ludoCoins": { "type": "number", "description": "Virtual currency earned through movement." },
        "psychomotorLevel": { "type": "number", "enum": [1, 2, 3, 4], "description": "1: Alicerce, 2: Movimento, 3: Precisão, 4: Ritmo" },
        "dailyCycle": {
          "type": "object",
          "properties": {
            "homeMissionCompleted": { "type": "boolean" },
            "streetMissionCompleted": { "type": "boolean" },
            "lastResetDate": { "type": "string" }
          }
        },
        "avatar": {
          "type": "object",
          "properties": {
            "energy": { "type": "number" },
            "unlockedItems": { "type": "array", "items": { "type": "string" } },
            "equippedItems": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["id", "ludoCoins", "psychomotorLevel"]
    },
    "ChallengeActivity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChallengeActivity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userProgressId": { "type": "string" },
        "challengeDefinitionId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" },
        "ludoCoinsEarned": { "type": "number" },
        "missionType": { "type": "string", "enum": ["home", "street"] },
        "psychomotorLevelAtTime": { "type": "number" }
      },
      "required": ["id", "userProgressId", "startTime", "isCompleted"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_progress/{userId}",
        "definition": {
          "entityName": "UserProgress",
          "schema": { "$ref": "#/backend/entities/UserProgress" },
          "description": "User profile with gamification and psychomotor progression."
        }
      },
      {
        "path": "/user_progress/{userId}/challenge_activities/{activityId}",
        "definition": {
          "entityName": "ChallengeActivity",
          "schema": { "$ref": "#/backend/entities/ChallengeActivity" },
          "description": "History of activities."
        }
      }
    ]
  }
}
