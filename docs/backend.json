
{
  "entities": {
    "UserProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProgress",
      "type": "object",
      "description": "Tracks progress, streaks, and profile data for an anonymous or registered user.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "ludoCoins": { "type": "number" },
        "psychomotorLevel": { "type": "number", "enum": [1, 2, 3, 4] },
        "ageGroup": { "type": "string", "enum": ["preschool", "school_age", "adolescent_adult"] },
        "sex": { "type": "string", "enum": ["male", "female", "other", "prefer_not_to_say"] },
        "neurodivergence": { "type": "string", "description": "Information about neurodivergence for challenge adaptation." },
        "physicalLimitations": { "type": "string", "description": "Physical constraints to ensure safe challenges." },
        "skillLevel": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "badges": { "type": "array", "items": { "type": "string" } },
        "equippedBadges": { "type": "array", "items": { "type": "string" } },
        "totalLikesReceived": { "type": "number", "default": 0 },
        "termsAccepted": { "type": "boolean", "default": false },
        "avatar": {
          "type": "object",
          "properties": {
            "energy": { "type": "number" },
            "unlockedItems": { "type": "array", "items": { "type": "string" } },
            "equippedItems": { "type": "array", "items": { "type": "string" } },
            "studioLevel": { "type": "number" },
            "traits": {
              "type": "object",
              "properties": {
                "hair": { "type": "string" },
                "hairColor": { "type": "string" },
                "hairTexture": { "type": "string" },
                "eyeColor": { "type": "string" },
                "eyeShape": { "type": "string" },
                "skinTone": { "type": "string" },
                "faceShape": { "type": "string" },
                "accessories": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "dailyCycle": {
          "type": "object",
          "properties": {
            "homeMissionCompleted": { "type": "boolean" },
            "streetMissionCompleted": { "type": "boolean" },
            "lastResetDate": { "type": "string" }
          }
        }
      },
      "required": ["id", "ludoCoins", "psychomotorLevel"]
    },
    "ChallengeActivity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChallengeActivity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userProgressId": { "type": "string" },
        "userName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" },
        "ludoCoinsEarned": { "type": "number" },
        "missionType": { "type": "string", "enum": ["home", "street"] },
        "challengeTitle": { "type": "string" },
        "challengeDescription": { "type": "string" },
        "photoUrl": { "type": "string", "description": "URL or DataURI of the proof photo." },
        "likes": { "type": "number", "default": 0 },
        "isPublic": { "type": "boolean", "default": false }
      },
      "required": ["id", "userProgressId", "startTime", "isCompleted"]
    }
  },
  "auth": {
    "providers": ["anonymous", "google", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_progress/{userId}",
        "definition": {
          "entityName": "UserProgress",
          "schema": { "$ref": "#/backend/entities/UserProgress" },
          "description": "Public and private user profile data."
        }
      },
      {
        "path": "/user_progress/{userId}/challenge_activities/{activityId}",
        "definition": {
          "entityName": "ChallengeActivity",
          "schema": { "$ref": "#/backend/entities/ChallengeActivity" },
          "description": "History of user activities."
        }
      },
      {
        "path": "/public_gallery/{activityId}",
        "definition": {
          "entityName": "ChallengeActivity",
          "schema": { "$ref": "#/backend/entities/ChallengeActivity" },
          "description": "Shared public activities for the community feed."
        }
      }
    ]
  }
}
